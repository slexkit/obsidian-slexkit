{
  "name": "@slexkit/obsidian",
  "version": "0.3.3",
  "description": "Adapter for explicit slex fences powered by SlexKit.",
  "author": "SlexKit contributors",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slexkit/obsidian-slexkit.git"
  },
  "homepage": "https://github.com/slexkit/obsidian-slexkit#readme",
  "bugs": {
    "url": "https://github.com/slexkit/obsidian-slexkit/issues"
  },
  "main": "./main.js",
  "files": [
    "main.js",
    "manifest.json",
    "versions.json",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run build && bun run typecheck && bun run test && bun run smoke:release",
    "community:check": "node scripts/community-check.mjs",
    "community:entry": "node scripts/apply-community-entry.mjs --print",
    "vault:smoke": "node scripts/prepare-vault-smoke.mjs",
    "test": "bun test --conditions browser --preload ./tests/setup.ts tests",
    "smoke:release": "node scripts/release-smoke.mjs",
    "publish:npm": "node scripts/publish-npm.mjs"
  },
  "keywords": [
    "slexkit",
    "obsidian",
    "markdown",
    "renderer"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "slexkit": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "slexkit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^25.0.0",
    "obsidian": "^1.12.3",
    "slexkit": "^0.3.0",
    "typescript": "^5.7.0"
  }
}
